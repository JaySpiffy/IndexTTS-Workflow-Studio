# Draft to Take beta example environment.
# Copy to .env only if you want to override defaults.

DRAFT_TO_TAKE_IMAGE_PREFIX=ghcr.io/jayspiffy
DRAFT_TO_TAKE_IMAGE_TAG=v3.0.0-beta.4

# start.bat sets DRAFT_TO_TAKE_SHARED_DIR to:
# %USERPROFILE%\DraftToTake\shared
# You can override it here if you know what you are doing.
# DRAFT_TO_TAKE_SHARED_DIR=C:\Users\you\DraftToTake\shared

INDTEXTS_FRONTEND_HOST_PORT=3000
INDTEXTS_BACKEND_HOST_PORT=8001
INDTEXTS_USE_GPU=true
INDTEXTS_DEVICE=auto
INDTEXTS_USE_FP16=auto
INDTEXTS_USE_DEEPSPEED=true

INDTEXTS_AUTO_DOWNLOAD_MODELS=true
INDTEXTS_MODEL_REPO=IndexTeam/IndexTTS-2
HF_TOKEN=

# Enabled by default in the beta launcher because Qwen powers emotion detection
# and the optional AI Thread.
INDTEXTS_SCRIPT_LLM_ENABLED=true
INDTEXTS_SCRIPT_LLM_HOST_PORT=8030
SCRIPT_LLM_AUTO_LOAD=true
SCRIPT_LLM_AUTO_DOWNLOAD=true
SCRIPT_LLM_MODEL_REPO_ID=ufoym/Qwen3-8B-Q4_K_M-GGUF
SCRIPT_LLM_MODEL_FILENAME=qwen3-8b-q4_k_m.gguf
SCRIPT_LLM_CTX_SIZE=10000
SCRIPT_LLM_GPU_LAYERS=-1
SCRIPT_LLM_PARALLEL=1
SCRIPT_LLM_DISABLE_THINKING=true

# Optional OmniVoice sidecar for reusable voice design.
INDTEXTS_OMNIVOICE_ENABLED=true
INDTEXTS_OMNIVOICE_HOST_PORT=8010
OMNIVOICE_DEVICE=auto
OMNIVOICE_MODEL_ID=k2-fsa/OmniVoice
OMNIVOICE_AUTO_DOWNLOAD=true
OMNIVOICE_DOWNLOAD_ON_START=true

# Optional SFX/music sidecar. It is off by default in the beta launcher because
# the current default model-backed generators are license-dependent and heavier.
INDTEXTS_SFX_ENABLED=false
INDTEXTS_SFX_HOST_PORT=8020
SFX_DEVICE=cuda
SFX_ALLOW_CPU_FALLBACK=false
SFX_ENGINE=woosh+musicgen
SFX_WOOSH_MODEL_NAME=Woosh-DFlow
SFX_WOOSH_WEIGHTS_REPO=AEmotionStudio/woosh-models
SFX_WOOSH_MODEL_ROOT=/app/shared/models/woosh
SFX_WOOSH_AUTO_DOWNLOAD=true
MUSIC_MODEL_ID=facebook/musicgen-small
